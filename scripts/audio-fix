#!/usr/bin/env bash
set -euo pipefail

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"

# Restart audio stack to clear bad jack/routing state
systemctl --user restart wireplumber pipewire pipewire-pulse
sleep 1

# Prefer stable motherboard analog sink (green jack)
sink_id="$(wpctl status | sed -n 's/^[^0-9]*\([0-9]\+\)\.\s\+Built-in Audio Analog Stereo.*/\1/p' | head -n1)"
if [ -n "${sink_id:-}" ]; then
  wpctl set-default "$sink_id"
  wpctl set-mute "$sink_id" 0
  wpctl set-volume "$sink_id" 0.75
  pw-metadata -n default 0 default.audio.sink '{ "name": "alsa_output.pci-0000_00_1f.3.analog-stereo" }' >/dev/null || true
fi

wpctl status | sed -n '1,80p'
