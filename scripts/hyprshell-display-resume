#!/usr/bin/env bash
set -euo pipefail

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$UID}"
lock_file="$runtime_dir/hyprshell-display-resume.lock"

# Suspend resume and Hypridle's DPMS listener can fire together. Let one
# invocation own the recovery so Hyprshell is restarted only once.
exec 9>"$lock_file"
if ! /run/current-system/sw/bin/flock -n 9; then
  exit 0
fi

/run/current-system/sw/bin/hyprctl dispatch dpms on >/dev/null 2>&1 || true
/run/current-system/sw/bin/brightnessctl -r >/dev/null 2>&1 || true

# Hyprshell cannot rebuild its switcher while Hyprland has no active monitor.
# Wait for the monitor to return before replacing the failed GUI instance.
for _ in {1..40}; do
  if /run/current-system/sw/bin/hyprctl monitors -j 2>/dev/null \
    | /run/current-system/sw/bin/grep -q '"disabled": false'; then
    /run/current-system/sw/bin/sleep 0.5
    /run/current-system/sw/bin/systemctl --user restart hyprshell.service
    /run/current-system/sw/bin/logger -t hyprshell-display-resume \
      "restarted hyprshell after an active monitor returned"
    exit 0
  fi
  /run/current-system/sw/bin/sleep 0.25
done

/run/current-system/sw/bin/logger -t hyprshell-display-resume \
  "active monitor did not return within 10 seconds"
exit 1
