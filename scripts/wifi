#!/usr/bin/env bash
set -euo pipefail

if command -v nm-connection-editor >/dev/null 2>&1; then
  exec nm-connection-editor
elif command -v nmtui >/dev/null 2>&1; then
  exec ghostty --class=org.omanix.wifi -e nmtui
else
  echo "No Wi-Fi UI found. Install NetworkManager tools or nmtui." >&2
  exit 1
fi
