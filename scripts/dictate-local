#!/usr/bin/env bash
set -euo pipefail

MODEL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/whisper.cpp/models"
MODEL_FILE="${DICTATE_MODEL:-$MODEL_DIR/ggml-base.en.bin}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
TS="$(date +%Y%m%d-%H%M%S)"
WAV="$RUNTIME_DIR/dictate-$TS.wav"
OUT_BASE="$RUNTIME_DIR/dictate-$TS"
DURATION="${DICTATE_DURATION:-12}"

mkdir -p "$MODEL_DIR"

if [[ ! -f "$MODEL_FILE" ]]; then
  notify-send "Dictation model missing" "Run: dictate-local-setup" -u critical -t 5000 || true
  echo "Model missing: $MODEL_FILE" >&2
  exit 1
fi

# Capture microphone audio via PipeWire/Pulse default source.
ffmpeg -y -loglevel error -f pulse -i default -t "$DURATION" -ac 1 -ar 16000 "$WAV"

# Transcribe and copy final text to clipboard.
whisper-cli -m "$MODEL_FILE" -f "$WAV" -otxt -of "$OUT_BASE" >/dev/null 2>&1
TXT_FILE="$OUT_BASE.txt"
if [[ ! -s "$TXT_FILE" ]]; then
  notify-send "Dictation failed" "No transcript produced" -u critical -t 4000 || true
  exit 1
fi

TEXT="$(tr '\n' ' ' < "$TXT_FILE" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
printf '%s' "$TEXT" | wl-copy
notify-send "Dictation ready" "Transcript copied to clipboard" -t 2500 || true
printf '%s\n' "$TEXT"
