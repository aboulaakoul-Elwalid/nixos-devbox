# AI Coding Project Environment Template
# Copy this to your project as .envrc
# Then run: direnv allow

# ------------------ API Keys ------------------
# Uncomment and fill in your keys
# These are loaded only in this project directory

# export ANTHROPIC_API_KEY="sk-ant-..."
# export OPENAI_API_KEY="sk-..."
# export GEMINI_API_KEY="..."
# export GROQ_API_KEY="..."

# Or load from a gitignored .env.local file
dotenv_local

# ------------------ Project Environment ------------------
# Uncomment ONE of these based on your project type:

# Python project with venv
# layout python python3.12

# Node.js project
# use_node 22

# Rust project
# layout rust

# Go project
# layout go

# Nix flake project (recommended for reproducibility)
# use nix

# ------------------ Path Additions ------------------
# Add local scripts to PATH
use_local_bin

# ------------------ Project-Specific Variables ------------------
# export PROJECT_NAME="my-ai-project"
# export DEBUG=1
