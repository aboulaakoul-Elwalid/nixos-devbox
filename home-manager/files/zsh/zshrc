# Safe interactive rm: move to FreeDesktop Trash instead of permanent delete.
# Permanent delete: command rm ...   or   /run/current-system/sw/bin/rm ...
# Restore from: ~/.local/share/Trash/files
rm() {
  local -a paths
  local arg
  for arg in "$@"; do
    case "$arg" in
      -*) ;;
      *) paths+=("$arg") ;;
    esac
  done
  if (( ${#paths} == 0 )); then
    print -u2 "rm: missing operand (trash mode; use 'command rm' for permanent delete)"
    return 1
  fi
  gio trash -- "${paths[@]}"
}
