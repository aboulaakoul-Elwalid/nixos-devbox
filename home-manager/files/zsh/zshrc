# Video transcodes
transcode-video-1080p() {
  if [ $# -ne 1 ]; then
    echo "Usage: transcode-video-1080p <input-file>"
    return 1
  fi
  local in="$1" out="${1%.*}-1080p.mp4"
  ffmpeg -i "$in" -vf scale=1920:1080 -c:v libx264 -preset fast -crf 23 -c:a copy "$out"
}

transcode-video-4K() {
  if [ $# -ne 1 ]; then
    echo "Usage: transcode-video-4K <input-file>"
    return 1
  fi
  local in="$1" out="${1%.*}-4k-optimized.mp4"
  ffmpeg -i "$in" -c:v libx265 -preset slow -crf 24 -c:a aac -b:a 192k "$out"
}

# Image operations (requires ImageMagick)
img2jpg() {
  if [ $# -ne 1 ]; then echo "Usage: img2jpg <image>"; return 1; fi
  magick "$1" -quality 95 -strip "${1%.*}.jpg"
}
img2jpg-small() {
  if [ $# -ne 1 ]; then echo "Usage: img2jpg-small <image>"; return 1; fi
  magick "$1" -resize 1080x\> -quality 95 -strip "${1%.*}.jpg"
}
img2png() {
  if [ $# -ne 1 ]; then echo "Usage: img2png <image>"; return 1; fi
  magick "$1" -strip -define png:compression-filter=5 \
    -define png:compression-level=9 \
    -define png:compression-strategy=1 \
    -define png:exclude-chunk=all \
    "${1%.*}.png"
}
