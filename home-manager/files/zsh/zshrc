# Initialize a new project with nix flake + direnv
nix-init() {
  local template="${1:-ai}"
  local templates_dir="$HOME/.config/nix/templates"
  
  if [[ ! -d "$templates_dir/$template" ]]; then
    echo "Available templates:"
    ls -1 "$templates_dir" 2>/dev/null | sed 's/^/  /'
    echo ""
    echo "Usage: nix-init <template>"
    echo "Example: nix-init python"
    return 1
  fi
  
  if [[ -f flake.nix ]]; then
    echo "flake.nix already exists in this directory"
    return 1
  fi
  
  echo "Initializing $template project..."
  cp "$templates_dir/$template/flake.nix" .
  
  # Create .envrc for direnv
  if [[ ! -f .envrc ]]; then
    echo "use flake" > .envrc
    echo "dotenv_local" >> .envrc
  fi
  
  # Create .env.local template for secrets
  if [[ ! -f .env.local ]]; then
    echo "# Project secrets (gitignored)" > .env.local
    echo "# ANTHROPIC_API_KEY=" >> .env.local
  fi
  
  # Add to gitignore
  if [[ ! -f .gitignore ]]; then
    echo ".direnv/" > .gitignore
    echo ".env.local" >> .gitignore
    echo ".venv/" >> .gitignore
    echo "result" >> .gitignore
  else
    grep -q ".direnv" .gitignore || echo ".direnv/" >> .gitignore
    grep -q ".env.local" .gitignore || echo ".env.local" >> .gitignore
  fi
  
  echo "Created:"
  echo "  flake.nix   - Nix development environment"
  echo "  .envrc      - direnv configuration"
  echo "  .env.local  - Secret environment variables (gitignored)"
  echo ""
  echo "Run 'direnv allow' to activate the environment"
}

# Quick project environment setup without nix (just direnv + venv)
project-init() {
  local type="${1:-python}"
  local templates_dir="$HOME/.config/direnv/templates"
  
  case "$type" in
    python)
      cp "$templates_dir/python.envrc" .envrc
      ;;
    ai)
      cp "$templates_dir/ai-project.envrc" .envrc
      ;;
    nix)
      cp "$templates_dir/nix.envrc" .envrc
      ;;
    *)
      echo "Usage: project-init <type>"
      echo "Types: python, ai, nix"
      return 1
      ;;
  esac
  
  # Create .env.local for secrets
  if [[ ! -f .env.local ]]; then
    echo "# Project secrets (gitignored)" > .env.local
  fi
  
  # Add to gitignore
  if [[ ! -f .gitignore ]]; then
    echo ".direnv/" > .gitignore
    echo ".env.local" >> .gitignore
    echo ".venv/" >> .gitignore
  fi
  
  echo "Created .envrc ($type template)"
  echo "Run 'direnv allow' to activate"
}

