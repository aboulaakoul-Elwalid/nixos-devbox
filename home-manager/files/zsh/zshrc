# Clear all exited Zellij sessions
zellij-clear() {
  # Strip ANSI color codes for proper parsing
  local sessions=$(zellij list-sessions 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g')
  local exited_count=$(echo "$sessions" | grep -i "EXITED" | wc -l)
  if [ "$exited_count" -gt 0 ]; then
    echo "Clearing $exited_count exited session(s)..."
    echo "$sessions" | grep -i "EXITED" | awk '{print $1}' | while read session; do
      echo "  Removing: $session"
      zellij delete-session "$session" 2>/dev/null || true
    done
    echo "Done!"
  else
    echo "No exited sessions to clear"
  fi
}

