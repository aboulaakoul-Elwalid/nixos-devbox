# ------------------ Functions ------------------
# Robust cd with zoxide fallback
cd() {
  if [ $# -eq 0 ]; then
    builtin cd || return $?
    return 0
  fi
  if builtin cd -- "$@" 2>/dev/null; then
    return 0
  fi
  if command -v zoxide >/dev/null 2>&1; then
    local target
    target=$(zoxide query -- "${*}" 2>/dev/null || true)
    target=${target%%$'\n'*}
    if [ -n "$target" ] && [ "$PWD" != "$target" ]; then
      builtin cd -- "$target" && return 0
    fi
    if command -v z >/dev/null 2>&1; then
      z "$@" 2>/dev/null && return 0 || true
    fi
  fi
  echo "cd: no such file or fuzzy match for: $*" >&2
  return 1
}

# ff - fuzzy-find files and open in $EDITOR
ff() {
  local term="${1:-}"
  if ! command -v fzf >/dev/null 2>&1; then
    echo "ff: fzf is required. Install fzf." >&2
    return 1
  fi

  local fd_cmd preview selection
  if command -v fd >/dev/null 2>&1; then
    fd_cmd=(fd --type f --hidden --follow --exclude .git --search-path . ${term:+-- "$term"})
  else
    fd_cmd=(find . -type f -not -path '*/.git/*' ${term:+-iname "*${term}*"})
  fi

  if command -v bat >/dev/null 2>&1; then
    preview='bat --style=numbers --color=always --line-range :200 {}'
  else
    preview='sed -n "1,200p" {}'
  fi

  selection="$("${fd_cmd[@]}" 2>/dev/null | fzf --prompt='Files> ' --height=40% --layout=reverse --info=inline --preview "$preview")"
  if [ -n "$selection" ]; then
    if [ -n "$EDITOR" ]; then
      "$EDITOR" "$selection"
    elif command -v nvim >/dev/null 2>&1; then
      nvim "$selection"
    elif command -v code >/dev/null 2>&1; then
      code "$selection"
    else
      ${PAGER:-less} "$selection"
    fi
  fi
}

# compress/decompress helpers
compress() {
  if [ $# -lt 2 ]; then
    echo "Usage: compress <archive.tar.gz> <files...>" >&2
    return 1
  fi
  local archive="$1"; shift
  tar -czvf "$archive" "$@"
}

decompress() {
  if [ $# -lt 1 ]; then
    echo "Usage: decompress <archive.tar.gz> [tar-args]" >&2
    return 1
  fi
  local archive="$1"; shift
  tar -xzvf "$archive" "$@"
}

