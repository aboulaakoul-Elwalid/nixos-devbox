# iso2sd: write ISO to block device (with strong confirmation)
iso2sd() {
  if [ $# -ne 2 ]; then
    echo "Usage: iso2sd <input.iso> <device>   (e.g. iso2sd ~/Downloads/foo.iso /dev/sdX)"
    echo ""
    echo "Available removable devices:"
    lsblk -o NAME,MODEL,SIZE,TYPE,RM | awk '$4=="disk"{print "/dev/"$1"  "$2"  "$3}'
    return 1
  fi
  local iso="$1" dev="$2"
  [ -f "$iso" ] || { echo "File not found: $iso"; return 1; }
  [[ "$dev" =~ ^/dev/ ]] || { echo "Device must start with /dev/"; return 1; }
  lsblk "$dev" >/dev/null 2>&1 || { echo "Device not found: $dev"; return 1; }
  echo "About to write $iso -> $dev (ALL DATA WILL BE LOST)."
  read -r "?Type YES to continue: " ans
  if [[ "$ans" == "YES" ]]; then
    sudo dd if="$iso" of="$dev" bs=4M status=progress oflag=sync conv=fsync
    sudo eject "$dev" 2>/dev/null || true
  else
    echo "Aborted."
  fi
}

# format-drive: whole device -> single ext4 partition
format-drive() {
  if [ $# -ne 2 ]; then
    echo "Usage: format-drive <device> <label>"
    echo "Example: format-drive /dev/sdX MyDrive"
    lsblk -d -o NAME,SIZE,MODEL | awk '{print "/dev/"$1"  "$2"  "$3}'
    return 1
  fi
  local dev="$1" label="$2"
  [[ "$dev" =~ ^/dev/ ]] || { echo "Device must start with /dev/"; return 1; }
  lsblk "$dev" >/dev/null 2>&1 || { echo "Device not found: $dev"; return 1; }
  echo "WARNING: This will WIPE $dev and label it '$label'."
  read -r "?Really proceed (type ERASE)? " confirm
  [[ "$confirm" == "ERASE" ]] || { echo "Aborted."; return 1; }
  sudo wipefs -a "$dev"
  sudo dd if=/dev/zero of="$dev" bs=1M count=64 status=progress
  sudo parted -s "$dev" mklabel gpt
  sudo parted -s "$dev" mkpart primary ext4 1MiB 100%
  local part
  if [[ "$dev" == *"nvme"* ]]; then
    part="${dev}p1"
  else
    part="${dev}1"
  fi
  sudo mkfs.ext4 -L "$label" "$part"
  echo "Formatted $part as ext4 label=$label"
}

